{
	"name": "greatfrontend",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint --max-warnings 0",
		"typecheck": "tsc --noEmit",
